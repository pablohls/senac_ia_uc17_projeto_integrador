# Dados (reprodutíveis via src/coleta) — não versionar o corpus,
# mas manter a estrutura de pastas no git via .gitkeep
dados/**
!dados/**/
!dados/**/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

# Modelos / embeddings / artefatos pesados
*.pt
*.bin
embeddings/
models/

# NOTA: *.parquet e *.npy NÃO são ignorados aqui — são rastreados via Git LFS
# (ver .gitattributes). O corpus de `dados/` segue ignorado acima (reprodutível).
